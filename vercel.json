{
  "redirects": [
    {
      "source": "/privacy",
      "destination": "/privacy-policy",
      "permanent": true
    },
    {
      "source": "/terms",
      "destination": "/terms-of-service",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.(?:xml|txt|ico|png|jpg|jpeg|webp|svg|gif|css|js|woff|woff2|ttf|map|json)$).*)",
      "destination": "/index.html"
    }
  ]
}
